# Groq API Key - get one free at https://console.groq.com
# Single-key setups: just set GROQ_API_KEY (used automatically if no numbered keys below are set).
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------------
# OPTIONAL: Multi-key rotation & failover (Phase 2). If you set any GROQ_API_KEY_1..10,
# they take priority over the single GROQ_API_KEY above. The backend automatically
# round-robins between them and fails over to the next key on rate-limit/quota errors.
# You can set as few or as many as you have — they don't need to be contiguous... but
# contiguous numbering starting at 1 is recommended for clarity.
# ---------------------------------------------------------------------------------

GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=


# Server port
PORT=5000

# Comma-separated list of allowed origins (your frontend URL)
CLIENT_ORIGIN=https://genze-eduverse-frontend-production.up.railway.app

# Groq model to use for text chat
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Backup text model, used automatically if the primary model errors/is unavailable
GROQ_TEXT_MODEL_FALLBACK=llama-3.1-8b-instant

# Groq model to use for vision (image) requests — OCR, handwriting, diagrams, charts
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Backup vision model, used automatically if the primary vision model errors/is unavailable
GROQ_VISION_MODEL_FALLBACK=meta-llama/llama-4-maverick-17b-128e-instruct

# ===== ADMIN PANEL (required to enable /admin) =====
# Admin username (plaintext is fine here — this file never reaches the browser)
ADMIN_USERNAME=EduVerse

# bcrypt hash of the admin password. Generate with:
#   node utils/generatePasswordHash.js "1234"
# Never put the plaintext password in this file.
ADMIN_PASSWORD_HASH=$2a$12$5zO4cGwdcqkxUOkVE1Jqu.xJZ8cJzinPIEC1QbAz9KwZVYgPsenES

# Secret used to sign admin JWT sessions. Use a long random string in production,
# e.g. `openssl rand -hex 32`. Rotating this invalidates all active admin sessions.
JWT_SECRET=replace_with_a_long_random_secret

# How long an admin session stays valid.
JWT_EXPIRES_IN=8h
